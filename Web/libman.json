{
  "version": "3.0",
  "defaultProvider": "jsdelivr",
  "defaultDestination": "wwwroot/lib",
  "libraries": [
    {
      "library": "bootstrap@5.3.8",
      "destination": "wwwroot/lib/bootstrap",
      "files": [
        "LICENSE",
        "package.json",
        "README.md",
        "dist/css/bootstrap.css",
        "dist/css/bootstrap.css.map",
        "dist/css/bootstrap.min.css",
        "dist/css/bootstrap.min.css.map",
        "dist/js/bootstrap.bundle.js",
        "dist/js/bootstrap.bundle.js.map",
        "dist/js/bootstrap.bundle.min.js",
        "dist/js/bootstrap.bundle.min.js.map"
      ]
    },
    {
      "library": "jquery@4.0.0",
      "destination": "wwwroot/lib/jquery",
      "files": [
        "AUTHORS.txt",
        "LICENSE.txt",
        "package.json",
        "README.md",
        "dist/jquery.js",
        "dist/jquery.min.js",
        "dist/jquery.min.map"
      ]
    },
    {
      "library": "jquery-validation@1.22.1",
      "destination": "wwwroot/lib/jquery-validation",
      "files": [
        "LICENSE.md",
        "package.json",
        "README.md",
        "dist/jquery.validate.js",
        "dist/jquery.validate.min.js",
        "dist/additional-methods.js",
        "dist/additional-methods.min.js",
        "dist/localization/messages_ja.js",
        "dist/localization/messages_ja.min.js"
      ]
    },
    {
      "library": "jquery-validation-unobtrusive@4.0.0",
      "destination": "wwwroot/lib/jquery-validation-unobtrusive",
      "files": [
        "LICENSE.txt",
        "package.json",
        "README.md",
        "dist/jquery.validate.unobtrusive.js",
        "dist/jquery.validate.unobtrusive.min.js"
      ]
    },
    {
      "library": "bootswatch@5.3.8",
      "destination": "wwwroot/lib/bootswatch",
      "files": [
        "LICENSE",
        "package.json",
        "README.md",
        "dist/flatly/bootstrap.css",
        "dist/flatly/bootstrap.min.css",
        "dist/flatly/bootstrap.min.css.map"
      ]
    },
    {
      "library": "bootstrap-icons@1.13.1",
      "destination": "wwwroot/lib/bootstrap-icons",
      "files": [
        "LICENSE",
        "package.json",
        "README.md",
        "font/bootstrap-icons.scss",
        "font/bootstrap-icons.css",
        "font/bootstrap-icons.min.css",
        "font/fonts/bootstrap-icons.woff",
        "font/fonts/bootstrap-icons.woff2"
      ]
    },
    {
      "library": "tom-select@2.6.1",
      "destination": "wwwroot/lib/tom-select",
      "files": [
        "LICENSE",
        "package.json",
        "README.md",
        "dist/js/tom-select.popular.js",
        "dist/js/tom-select.popular.js.map",
        "dist/js/tom-select.popular.min.js",
        "dist/js/tom-select.popular.min.js.map",
        "dist/css/tom-select.bootstrap5.css",
        "dist/css/tom-select.bootstrap5.css.map",
        "dist/css/tom-select.bootstrap5.min.css",
        "dist/css/tom-select.bootstrap5.min.css.map"
      ]
    }
  ]
}