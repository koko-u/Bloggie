<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Ardalis.SmartEnum" />
    <PackageReference Include="Ardalis.SmartEnum.Dapper" />
    <PackageReference Include="Ardalis.SmartEnum.SystemTextJson" />
    <PackageReference Include="Ardalis.SmartEnum.ModelBinding" />
    <PackageReference Include="Dapper" />
    <PackageReference Include="FastCloner" />
    <PackageReference Include="FastCloner.SourceGenerator" />
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" />
    <PackageReference Include="KozLibraries.AutoRegisterAnnotation" />
    <PackageReference Include="kozlibraries.DapperDateOnlySupport" />
    <PackageReference Include="KozLibraries.JsonMessages" />
    <PackageReference Include="KozLibraries.TagHelpers" />
    <PackageReference Include="Markdig" />
    <PackageReference Include="Npgsql" />
    <PackageReference Include="Npgsql.DependencyInjection" />
    <PackageReference Include="Riok.Mapperly" ExcludeAssets="runtime" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Sql/**/*.sql" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
